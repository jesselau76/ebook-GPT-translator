# Provider: codex, claude, gemini, openai, azure, compatible, or mock
EBOOK_TRANSLATOR_PROVIDER=codex
# Model examples: gpt-5.2-codex (codex), claude-sonnet-4-6 (claude), gemini-3-pro-preview (gemini)
EBOOK_TRANSLATOR_MODEL=gpt-5.2-codex
EBOOK_TRANSLATOR_REASONING_EFFORT=medium
EBOOK_TRANSLATOR_API_KEY=
EBOOK_TRANSLATOR_API_BASE_URL=
EBOOK_TRANSLATOR_API_VERSION=
EBOOK_TRANSLATOR_API_MODE=auto
EBOOK_TRANSLATOR_TARGET_LANGUAGE=Simplified Chinese
EBOOK_TRANSLATOR_CONTEXT_WINDOW_BLOCKS=6
EBOOK_TRANSLATOR_GLOSSARY=
EBOOK_TRANSLATOR_OUTPUT_DIR=output
